        "query": "WITH ordered AS (\n  SELECT\n    *,\n    LAG(card_limit) OVER (\n      PARTITION BY card\n\t  ORDER BY created_at, id\n    ) AS prev_card_limit\n  FROM transactions\n)\nSELECT *\nFROM ordered\nWHERE prev_card_limit IS NOT NULL\n  AND card_limit <> prev_card_limit - amount\n  AND ROUND(card_limit, 2) <> ROUND(prev_card_limit - amount, 2)\nORDER BY card, created_at;\n",
