      "parameters": {
        "jsCode": "const transactions = $input.first().json.data;\n\nlet message = \"📅 *Resoconto Spese del Mese*\\n\\n\";\nlet grandTotal = 0;\n\n// Ordina carte per importo decrescente\ntransactions.sort((a, b) => parseFloat(b.total_amount) - parseFloat(a.total_amount));\n\nfor (const item of transactions) {\n  const amount = parseFloat(item.total_amount) || 0;\n  grandTotal += amount;\n\n  message += `💳 *Carta ${item.card}:* ${amount.toFixed(2)} AED\\n`;\n}\n\nmessage += `\\n➖➖➖➖➖➖➖➖\\n`;\nmessage += `💰 *TOTALE COMPLESSIVO:* ${grandTotal.toFixed(2)} AED`;\n\nreturn {\n  json: {\n    telegram_text: message\n  }\n};\n"
