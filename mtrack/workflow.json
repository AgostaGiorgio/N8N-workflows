    {
      "parameters": {
        "operation": "executeQuery",
        "query": "CREATE EXTENSION IF NOT EXISTS \"pgcrypto\";\nCREATE TYPE category_type AS ENUM ('primary', 'secondary');\nCREATE TABLE categories (\n  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n  name TEXT UNIQUE NOT NULL,\n  type category_type NOT NULL,\n  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n  icon TEXT,\n  UNIQUE (name, type) \n);\nCREATE TABLE category_mappings (\n  primary_id UUID REFERENCES categories(id) ON DELETE CASCADE,\n  secondary_id UUID REFERENCES categories(id) ON DELETE CASCADE,\n  PRIMARY KEY (primary_id, secondary_id)\n);\nCREATE TABLE transactions (\n  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n  description TEXT,\n  amount NUMERIC(12, 2) NOT NULL,\n  card TEXT,\n  card_limit NUMERIC(12, 2) NOT NULL,\n  primary_category UUID REFERENCES categories(id) ON DELETE SET NULL,\n  secondary_category UUID REFERENCES categories(id) ON DELETE SET NULL\n);\nCREATE OR REPLACE FUNCTION extract_merchant_name(tx_description TEXT)\nRETURNS TEXT AS $$\nBEGIN\n    RETURN trim(COALESCE(\n        substring(tx_description from ' at (.*?)\\. Avl'),\n        substring(tx_description from ' to (.*?) with Credit Card'),\n        tx_description \n    ));\nEND;\n$$ LANGUAGE plpgsql IMMUTABLE;\nCREATE OR REPLACE FUNCTION predict_transaction_categories(\n    p_description TEXT, \n    OUT predicted_primary_id UUID, \n    OUT predicted_secondary_id UUID\n) AS $$\nDECLARE\n    v_merchant TEXT;\nBEGIN\n    v_merchant := extract_merchant_name(p_description);\n\n    SELECT primary_category_id, secondary_category_id\n    INTO predicted_primary_id, predicted_secondary_id\n    FROM transactions\n    WHERE extract_merchant_name(description) = v_merchant\n      AND primary_category_id IS NOT NULL\n    GROUP BY primary_category_id, secondary_category_id\n    ORDER BY count(*) DESC\n    LIMIT 1;\nEND;\n$$ LANGUAGE plpgsql;",
        "options": {}
      },
