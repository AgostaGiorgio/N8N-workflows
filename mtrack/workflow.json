    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH boundaries AS (\n  SELECT\n    CASE\n      WHEN EXTRACT(DAY FROM current_date) >= 3\n        THEN date_trunc('month', current_date) + interval '2 days'\n      ELSE\n        date_trunc('month', current_date) - interval '1 month' + interval '2 days'\n    END AS bank_start\n),\nweek_calc AS (\n  SELECT\n    GREATEST(\n      date_trunc('week', current_date),\n      bank_start\n    ) AS week_start,\n    LEAST(\n      date_trunc('week', current_date) + interval '7 days',\n      bank_start + interval '1 month'\n    ) AS week_end\n  FROM boundaries\n)\nSELECT SUM(amount) AS total_amount, card\nFROM transactions, week_calc\nWHERE created_at >= week_start\n  AND created_at < week_end\nGROUP BY card;\n",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
