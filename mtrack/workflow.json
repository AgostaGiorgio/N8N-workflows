    {
      "parameters": {
        "jsCode": "let messages = [];\n\nconst regex = /Incongruenza rilevata per Carta\\s+(\\d{4})[\\s\\S]*?Ultimo Limite\\s*→\\s*(\\d+(?:\\.\\d+)?)\\s*AED[\\s\\S]*?Differenza\\s*→\\s*(\\d+(?:\\.\\d+)?)\\s*AED/;\n\nfor (const item of $input.first().json.result) {\n  const replyText = item.message?.reply_to_message?.text;\n  const date = item.message?.text;\n\n  if (replyText && regex.test(replyText)) {\n    const match = replyText.match(regex);\n\n    if (match){\n      const card = match[1];\n      const lastLimit = parseFloat(match[2]);\n      const amount = parseFloat(match[3]);\n      \n      const card_limit = (lastLimit - amount).toFixed(2);\n\n      messages.push({\n        card,\n        card_limit: parseFloat(card_limit),\n        amount,\n        date: date.replace(\" \", \"T\") + \":00Z\",\n        \"description\": \"Manual transaction\",\n        \"update_id\": item.update_id\n      });\n    }\n  }\n}\n\nreturn messages;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        560
      ],
