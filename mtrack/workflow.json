      "parameters": {
        "jsCode": "const transactions = $input.first().json.data;\n\nlet message = \"📅 *Resoconto Spese di Oggi \" + DateTime.now().toISODate() + \"*\\n\\n\";\nlet grandTotal = 0;\n\nfor (const item of transactions) {\n  const amount = parseFloat(item.total_amount);\n  \n  grandTotal += amount;\n  message += `💳 *Carta ${item.card}:* ${amount.toFixed(2)}\\n`;\n}\n\nmessage += `\\n➖➖➖➖➖➖➖➖\\n`;\nmessage += `💰 *TOTALE OGGI:* ${grandTotal.toFixed(2)}`;\n\nmessage += `\\n➖➖➖➖➖➖➖➖\\n`;\nmessage += `💰 *TOTALE MESE:* ${$input.first().json.total_amount}`;\n\nreturn {\n  json: {\n    telegram_text: message\n  }\n};"
      },
